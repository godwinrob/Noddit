# Production Environment Variables for GCP e2-micro Deployment
# Copy this to .env.production and fill in the values

# Database
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_BASE64_SECRET

# Clerk Authentication (if using Clerk)
CLERK_SECRET_KEY=sk_live_YOUR_SECRET_KEY
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_PUBLIC_KEY

# VM External IP (will be filled automatically during deployment)
EXTERNAL_IP=WILL_BE_FILLED_BY_SETUP_SCRIPT
