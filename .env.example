# ===========================================
# Noddit - Root Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# All services (Go backend + Next.js frontend) read from this file.
# Docker Compose also uses this for variable substitution.

# --- Clerk Authentication ---
# Get your keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Backend (Go) ---
PORT=8080
FRONTEND_URL=http://localhost:8081

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=userdb
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# User Defaults (for Clerk users)
CLERK_DEFAULT_ROLE=user
