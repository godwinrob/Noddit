# Server Configuration
PORT=8080
FRONTEND_URL=http://localhost:8081

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=userdb
DB_SSLMODE=disable

# Database Connection Pool
# Maximum number of open connections to the database
DB_MAX_OPEN_CONNS=25
# Maximum number of idle connections in the pool
DB_MAX_IDLE_CONNS=5

# Clerk Authentication
# Get your secret key from: https://dashboard.clerk.com
# For keyless mode (development), leave empty - Clerk will auto-generate
# For production, get your key after claiming your app in Clerk Dashboard
CLERK_SECRET_KEY=

# User Configuration
# Default role assigned to new users during registration
DEFAULT_USER_ROLE=user
# Default subnoddit ID to add to new user favorites (1 = "Cats")
DEFAULT_FAVORITE_SUBNODDIT_ID=1
# Default role for Clerk-authenticated users without explicit role metadata
CLERK_DEFAULT_ROLE=user
